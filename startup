#!/bin/bash
# Check for ungoogled-chromium or chromium
if command -v ungoogled-chromium &> /dev/null; then
    BROWSER="ungoogled-chromium"
elif command -v chromium &> /dev/null; then
    BROWSER="chromium"
else
    BROWSER=$(ls /nix/store/*/bin/chromium 2>/dev/null | head -n 1)
fi

if [ -z "$BROWSER" ]; then
    echo "Chromium not found"
    exit 1
fi

# Launch browser with stability flags
# --disable-dev-shm-usage: prevents crashes in container environments
# --no-sandbox: required for many container environments
# --disable-gpu: prevents GPU-related crashes
# --remote-debugging-port: allows for inspection if needed
exec "$BROWSER" \
    --no-sandbox \
    --disable-gpu \
    --disable-dev-shm-usage \
    --disable-software-rasterizer \
    --start-maximized \
    --no-first-run \
    --remote-debugging-port=9222
