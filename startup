#!/bin/bash
# Enable logging
exec > /tmp/startup.log 2>&1
set -x

# 1. Setup directories
rm -rf /tmp/chromium-data
mkdir -p /tmp/chromium-data

# 2. Find the browser
if command -v ungoogled-chromium &> /dev/null; then
    BROWSER="ungoogled-chromium"
elif command -v chromium &> /dev/null; then
    BROWSER="chromium"
else
    BROWSER=$(find /nix/store -maxdepth 4 -type f -executable -name "chromium" 2>/dev/null | head -n 1)
fi

if [ -z "$BROWSER" ]; then
    echo "Chromium not found"
    exit 1
fi

echo "Launching $BROWSER..."

# 3. Launch browser with absolute minimum flags to prevent crashes
# The 'exec' means this script's process becomes the browser process
# If the browser crashes, the script exits with the browser's exit code
exec "$BROWSER" \
    --no-sandbox \
    --disable-gpu \
    --user-data-dir=/tmp/chromium-data \
    --disable-dev-shm-usage \
    --no-first-run \
    --no-default-browser-check \
    "https://www.google.com"
