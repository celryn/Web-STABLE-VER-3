#!/usr/bin/env python3
import os
import subprocess
import threading
import time

def run_x11vnc():
    """Start x11vnc to capture the X display"""
    print("Starting x11vnc...")
    env = os.environ.copy()
    if "DISPLAY" not in env:
        env["DISPLAY"] = ":0"
    
    subprocess.Popen([
        "x11vnc",
        "-display", ":0",
        "-forever",
        "-shared",
        "-nopw",
        "-rfbport", "5900",
        "-localhost"
    ], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def run_browser():
    """Launch browser opening Google"""
    time.sleep(2)
    
    browser = None
    for cmd in ["ungoogled-chromium", "chromium"]:
        try:
            subprocess.run(["which", cmd], check=True, capture_output=True)
            browser = cmd
            break
        except subprocess.CalledProcessError:
            continue
    
    if not browser:
        try:
            res = subprocess.run("find /nix/store -maxdepth 4 -type f -executable -name 'chromium' | head -n 1", shell=True, capture_output=True, text=True, timeout=5)
            browser = res.stdout.strip()
        except:
            pass

    if not browser:
        print("Chromium not found")
        return

    print(f"Launching {browser} with Google...")
    
    env = os.environ.copy()
    if "DISPLAY" not in env:
        env["DISPLAY"] = ":0"
    
    subprocess.Popen([
        browser,
        "--no-sandbox",
        "--disable-gpu",
        "--user-data-dir=/tmp/chromium-data",
        "--disable-dev-shm-usage",
        "--no-first-run",
        "--no-default-browser-check",
        "https://www.google.com"
    ], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def run_novnc():
    """Start noVNC/websockify to serve VNC over HTTP on port 5000"""
    print("Starting noVNC on port 5000...")
    time.sleep(1)
    
    subprocess.run([
        "websockify",
        "--web", "/tmp/novnc",
        "0.0.0.0:5000",
        "localhost:5900"
    ])

if __name__ == "__main__":
    os.makedirs("/tmp/chromium-data", exist_ok=True)
    
    threading.Thread(target=run_x11vnc, daemon=True).start()
    threading.Thread(target=run_browser, daemon=True).start()
    
    run_novnc()
