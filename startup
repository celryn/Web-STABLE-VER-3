#!/bin/bash
# Enable logging
exec > /tmp/startup.log 2>&1
set -x

# 1. Setup directories
rm -rf /tmp/chromium-data
mkdir -p /tmp/chromium-data

# 2. Setup VNC Bridge (noVNC + websockify) to open port 5000
# Replit deployment requires an open port (5000 is standard)
NOVNC_PATH=$(find /nix/store -maxdepth 3 -type d -name "novnc" -path "*/share/novnc" 2>/dev/null | head -n 1)
WEBSOCKIFY_CMD=$(find /nix/store -maxdepth 3 -type f -executable -name "websockify" 2>/dev/null | head -n 1)

if [ -n "$WEBSOCKIFY_CMD" ] && [ -n "$NOVNC_PATH" ]; then
    # websockify --web [path to novnc] [port] [target]
    # This will open port 5000 and proxy it to the internal VNC server
    $WEBSOCKIFY_CMD 5000 localhost:5900 --web "$NOVNC_PATH" &
fi

# 3. Find the browser
if command -v ungoogled-chromium &> /dev/null; then
    BROWSER="ungoogled-chromium"
elif command -v chromium &> /dev/null; then
    BROWSER="chromium"
else
    BROWSER=$(find /nix/store -maxdepth 4 -type f -executable -name "chromium" 2>/dev/null | head -n 1)
fi

if [ -z "$BROWSER" ]; then
    echo "Chromium not found"
    exit 1
fi

echo "Launching $BROWSER..."

# 4. Launch browser and keep it running
while true; do
    "$BROWSER" \
        --no-sandbox \
        --disable-gpu \
        --user-data-dir=/tmp/chromium-data \
        --disable-dev-shm-usage \
        --no-first-run \
        --no-default-browser-check \
        "https://www.google.com"
    echo "Browser exited with code $?. Restarting in 1s..."
    sleep 1
done
