#!/bin/bash
# Try to find chromium or ungoogled-chromium
if command -v ungoogled-chromium &> /dev/null; then
    exec ungoogled-chromium --no-sandbox --remote-debugging-port=9222 --disable-gpu --headless
elif command -v chromium &> /dev/null; then
    exec chromium --no-sandbox --remote-debugging-port=9222 --disable-gpu --headless
else
    # Search nix store if not in path
    CHROMIUM_BIN=$(ls /nix/store/*/bin/chromium 2>/dev/null | head -n 1)
    if [ -n "$CHROMIUM_BIN" ]; then
        exec "$CHROMIUM_BIN" --no-sandbox --remote-debugging-port=9222 --disable-gpu --headless
    else
        echo "Chromium not found"
        exit 1
    fi
fi
