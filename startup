    subprocess.run(["pkill", "-9", "-f", f"x11vnc.*{display}"],     capture_output=True)
    subprocess.run(["pkill", "-9", "-f", f"chromium-data-{sid}"],   capture_output=True)
    subprocess.run(["pkill", "-9", "-f", f"websockify.*{ws_port}"], capture_output=True)
    for proc in slot_info.get('procs', []):
        try:
            proc.kill()
        except Exception:
            pass
    slot_info['procs'].clear()
    time.sleep(1.5)
    # Clear Chromium singleton locks
    data_dir = f"/tmp/chromium-data-{slot_id}"
    for lk in ["SingletonLock", "SingletonSocket", "SingletonCookie"]:
        try:
            os.remove(os.path.join(data_dir, lk))
        except FileNotFoundError:
            pass
    _reset_chromium_prefs(slot_id)
    # Remove from active map temporarily so _start_slot can re-register it
    with _session_lock:
        _active_slots.pop(slot_id, None)
    _start_slot(slot_id, username)


class _AppHandler(http.server.BaseHTTPRequestHandler):
    """Custom HTTP handler: serves files, handles login/restart API,
       and tunnels WebSocket upgrades to internal websockify."""

    def log_message(self, format, *args):
        pass  # suppress per-request logs

    # ── helpers ────────────────────────────────────────────────────────────────

    def _send_json(self, code, data):
        body = _json.dumps(data).encode()
        self.send_response(code)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Content-Length', str(len(body)))
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        self.wfile.write(body)

    def _auth_token(self):
        return self.headers.get('X-Auth-Token', '')

    # ── POST ───────────────────────────────────────────────────────────────────

    def do_POST(self):
        if self.path == '/api/login':
            length = int(self.headers.get('Content-Length', 0))
            try:
                body = _json.loads(self.rfile.read(length))
            except Exception:
                self._send_json(400, {'error': 'Bad request'})
                return
            username = body.get('username', '')
            password = body.get('password', '')
            if USERS().get(username) == password:
                with _session_lock:
                    # Kick any existing session for this account
                    old_token = _user_to_token.get(username)
                    old_slot  = None
                    if old_token:
                        old_slot = _token_to_slot.pop(old_token, None)
                        _sessions.pop(old_token, None)
                    # Make sure there is a free slot
                    if not _free_slots:
                        self._send_json(503, {'error': 'Server is full — try again later'})
                        return
                    slot_id = min(_free_slots)
                    _free_slots.discard(slot_id)
                    token = secrets.token_hex(32)
                    _sessions[token]       = username
                    _user_to_token[username] = token
                    _token_to_slot[token]  = slot_id
                # Stop old slot outside the lock
                if old_slot is not None:
                    threading.Thread(target=_stop_slot, args=(old_slot,), daemon=True).start()
                # Start new slot in background (client retries VNC until ready)
                threading.Thread(target=_start_slot, args=(slot_id, username), daemon=True).start()
                device_fp    = body.get('device_fp', 'unknown')
                device_label = body.get('device_label', 'Unknown')
                threading.Thread(
                    target=_record_device,
                    args=(username, device_fp, device_label),
                    daemon=True
                ).start()
                self._send_json(200, {'token': token, 'username': username})
            else:
                self._send_json(401, {'error': 'Invalid username or password'})

        elif self.path == '/api/restart':
            token = self._auth_token()
            if token not in _sessions:
                self._send_json(403, {'error': 'Unauthorized'})
                return
            with _session_lock:
                slot_id = _token_to_slot.get(token)
            if slot_id is None:
                self._send_json(503, {'error': 'No session slot found'})
                return
            self._send_json(200, {'ok': True})
            threading.Thread(target=_restart_slot, args=(slot_id,), daemon=True).start()

        elif self.path == '/api/admin/auth':
            if self._auth_token() not in _sessions:
                self._send_json(403, {'error': 'Unauthorized'})
                return
            length = int(self.headers.get('Content-Length', 0))
            try:
                body = _json.loads(self.rfile.read(length))
            except Exception:
                self._send_json(400, {'error': 'Bad request'})
                return
            if body.get('password', '') == _get_admin_pass():
                self._send_json(200, {'ok': True})
            else:
                self._send_json(401, {'error': 'Wrong password'})

        elif self.path == '/api/logout':
            token = self._auth_token()
            with _session_lock:
                username = _sessions.pop(token, None)
                if username and _user_to_token.get(username) == token:
                    _user_to_token.pop(username, None)
                slot_id = _token_to_slot.pop(token, None)
            if slot_id is not None:
                threading.Thread(target=_stop_slot, args=(slot_id,), daemon=True).start()
            self._send_json(200, {'ok': True})

        else:
            self.send_error(404)

    def do_OPTIONS(self):
        self.send_response(204)
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type, X-Auth-Token')
        self.end_headers()

    # ── GET ────────────────────────────────────────────────────────────────────

    def do_GET(self):
        # WebSocket tunnel
        if (self.headers.get('Upgrade', '').lower() == 'websocket' and
                '/websockify' in self.path):
            self._tunnel_websocket()
            return

        if self.path == '/api/me':
            token = self._auth_token()
            if token in _sessions:
                self._send_json(200, {'ok': True, 'username': _sessions[token]})
            else:
                self._send_json(401, {'error': 'Unauthorized'})
            return

        if self.path == '/api/admin/devices':
            if self._auth_token() not in _sessions:
                self._send_json(403, {'error': 'Unauthorized'})
                return
            with _devices_lock:
                data = _load_devices()
            self._send_json(200, data)
            return

        # Static file serving
        path = urllib.parse.urlparse(self.path).path
        if path == '/':
            path = '/index.html'
        file_path = os.path.join(NOVNC_WEB, path.lstrip('/'))
        if os.path.isfile(file_path):
            ext = os.path.splitext(file_path)[1]
            mime = {
                '.html': 'text/html', '.js': 'application/javascript',
                '.css': 'text/css', '.png': 'image/png',
                '.svg': 'image/svg+xml', '.ico': 'image/x-icon',
                '.wasm': 'application/wasm',
            }.get(ext, 'application/octet-stream')
            with open(file_path, 'rb') as fh:
                data = fh.read()
            self.send_response(200)
            self.send_header('Content-Type', mime)
            self.send_header('Content-Length', str(len(data)))
            self.end_headers()
            self.wfile.write(data)
        else:
            self.send_error(404)

    # ── WebSocket tunnel ───────────────────────────────────────────────────────

    def _tunnel_websocket(self):
        # Resolve which websockify port to use for this user's token
        params  = urllib.parse.parse_qs(urllib.parse.urlparse(self.path).query)
        token   = params.get('token', [''])[0]
        with _session_lock:
            if token not in _sessions:
                self.send_error(403, "Unauthorized")
                return
            slot_id   = _token_to_slot.get(token)
            slot_info = _active_slots.get(slot_id) if slot_id is not None else None
        if slot_info is None:
            self.send_error(503, "Browser session not ready")
            return
        ws_port = slot_info['ws_port']

        try:
            srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            srv.connect(('127.0.0.1', ws_port))
        except Exception as e:
            self.send_error(502, f"Upstream unavailable: {e}")
            return

        # Forward the original HTTP upgrade request upstream
        raw = f"GET {self.path} HTTP/1.1\r\n"
        for k, v in self.headers.items():
            raw += f"{k}: {v}\r\n"
        raw += "\r\n"
        srv.sendall(raw.encode())

        client = self.connection
        self.close_connection = False

        # Bidirectional tunnel via select
        while True:
            try:
                r, _, e = select.select([client, srv], [], [client, srv], 10)
            except Exception:
                break
            if e:
                break
            for s in r:
                try:
                    data = s.recv(65536)
                except Exception:
                    data = None
                if not data:
                    try:
                        srv.close()
                    except Exception:
                        pass
                    return
                other = srv if s is client else client
                try:
                    other.sendall(data)
                except Exception:
                    try:
                        srv.close()
                    except Exception:
                        pass
                    return
        try:
            srv.close()
        except Exception:
            pass


def run_app_server():
    """Run the main HTTP server on NOVNC_PORT."""
    server = http.server.ThreadingHTTPServer(('', NOVNC_PORT), _AppHandler)
    server.daemon_threads = True
    print(f"App server listening on :{NOVNC_PORT}")
    server.serve_forever()

if __name__ == "__main__":
    print("Cleaning up old processes...")
    kill_old_processes()
    setup_novnc_web()
    # Start the main HTTP server — browser sessions launch on-demand at login
    run_app_server()
