def run_xvfb():
    print("Starting Xvfb...")
    subprocess.run([
        "Xvfb", DISPLAY,
        "-screen", "0", "1200x800x24",
        "-ac"
    ])

def run_browser():
    browser = None
    for cmd in ["ungoogled-chromium", "chromium"]:
        try:
            subprocess.run(["which", cmd], check=True, capture_output=True)
            browser = cmd
            break
        except subprocess.CalledProcessError:
            continue

    if not browser:
        try:
            res = subprocess.run(
                "find /nix/store -maxdepth 4 -type f -executable -name 'chromium' | head -n 1",
                shell=True, capture_output=True, text=True
            )
            browser = res.stdout.strip()
        except Exception:
            pass

    if not browser:
        print("Chromium not found")
        return

    print(f"Launching {browser}...")
    env = os.environ.copy()
    env["DISPLAY"] = DISPLAY

    while True:
        try:
            subprocess.run([
                browser,
                "--no-sandbox",
                "--disable-gpu",
                "--user-data-dir=/tmp/chromium-data",
                "--disable-dev-shm-usage",
                "--no-first-run",
                "--no-default-browser-check",
                "--start-maximized",
                "--disable-extensions",
                "--disable-background-networking",
                "--disable-sync",
                "--disable-translate",
                "--disable-hang-monitor",
                "--disable-component-update",
                "--disable-default-apps",
                "--disable-client-side-phishing-detection",
                "--disable-features=TranslateUI,Translate",
                "--disable-renderer-backgrounding",
                "--disable-backgrounding-occluded-windows",
                "--metrics-recording-only",
                "--disk-cache-size=104857600",
                "--memory-pressure-off",
                "--max-tiles-for-interest-area=512",
                "--disable-session-crashed-bubble",
                "--force-device-scale-factor=1",
                "https://www.google.com"
            ], env=env)
        except Exception as e:
            print(f"Browser error: {e}")
            time.sleep(2)
        else:
            print("Browser exited, restarting in 2s...")
            time.sleep(2)

def run_x11vnc():
    print("Starting x11vnc...")
    time.sleep(3)
    while True:
        try:
            subprocess.run([
                "x11vnc",
                "-display", DISPLAY,
                "-nopw",
                "-rfbport", str(VNC_PORT),
                "-forever",
                "-shared",
                "-quiet",
                "-xdamage",
                "-threads",
                "-defer", "5",
                "-wait", "5",
                "-xrandr", "resize",
            ])
        except Exception as e:
            print(f"x11vnc error: {e}")
            time.sleep(2)
        else:
            time.sleep(1)

def run_novnc(vnc_host):
    if ":" in vnc_host:
        target = f"[{vnc_host}]:{VNC_PORT}"
    else:
        target = f"{vnc_host}:{VNC_PORT}"
    print(f"Starting noVNC on :{NOVNC_PORT} -> {target}")
    env = os.environ.copy()
    numpy_path = "/nix/store/12nkx5irbnfdh06frm3sxs7drdw9ah4r-python3.11-numpy-1.26.4/lib/python3.11/site-packages"
    existing = env.get("PYTHONPATH", "")
    env["PYTHONPATH"] = f"{numpy_path}:{existing}" if existing else numpy_path
    while True:
        try:
            subprocess.run([
                "websockify",
                "--web", NOVNC_WEB,
                str(NOVNC_PORT),
                target
            ], env=env)
        except Exception as e:
            print(f"noVNC error: {e}")
        time.sleep(3)

def reset_chromium_crash_flag():
    prefs_dir = "/tmp/chromium-data/Default"
    prefs_file = os.path.join(prefs_dir, "Preferences")
    os.makedirs(prefs_dir, exist_ok=True)
    if os.path.exists(prefs_file):
        try:
            import json
            with open(prefs_file, "r") as f:
                prefs = json.load(f)
            prefs.setdefault("profile", {})
            prefs["profile"]["exit_type"] = "Normal"
            prefs["profile"]["exited_cleanly"] = True
            with open(prefs_file, "w") as f:
                json.dump(prefs, f)
        except Exception:
            pass

