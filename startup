#!/bin/bash
# Enable logging
exec > /tmp/startup.log 2>&1
set -x

# 1. Clean up and setup directories
rm -rf /tmp/chromium-data
mkdir -p /tmp/chromium-data

# 2. Find the browser
if command -v ungoogled-chromium &> /dev/null; then
    BROWSER="ungoogled-chromium"
elif command -v chromium &> /dev/null; then
    BROWSER="chromium"
else
    BROWSER=$(find /nix/store -maxdepth 4 -type f -executable -name "chromium" 2>/dev/null | head -n 1)
fi

if [ -z "$BROWSER" ]; then
    echo "Chromium not found"
    exit 1
fi

echo "Launching $BROWSER..."

# 3. Launch browser with compatible flags for cloud environments
# Removing some extreme flags that might cause crashes in different environments
exec "$BROWSER" \
    --no-sandbox \
    --disable-gpu \
    --start-maximized \
    --no-first-run \
    --no-default-browser-check \
    --user-data-dir=/tmp/chromium-data \
    --disable-dev-shm-usage \
    --js-flags="--max-old-space-size=2048" \
    --disable-extensions \
    --disable-background-networking \
    --disable-sync \
    --disable-default-apps \
    --mute-audio \
    --disable-software-rasterizer \
    --disable-breakpad \
    --disable-hang-monitor \
    --disable-renderer-backgrounding \
    --num-raster-threads=2 \
    "https://www.google.com"
