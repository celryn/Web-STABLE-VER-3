#!/bin/bash
# Enable logging
exec > /tmp/startup.log 2>&1
set -x

echo "Starting chromium launch script..."

# Find the browser
if command -v ungoogled-chromium &> /dev/null; then
    BROWSER="ungoogled-chromium"
elif command -v chromium &> /dev/null; then
    BROWSER="chromium"
else
    # Fallback to absolute path
    BROWSER="/nix/store/43y6k6fj85l4kcd1yan43hpdld6nmjmp-ungoogled-chromium-131.0.6778.204/bin/chromium"
fi

echo "Launching $BROWSER with Google..."

# Launch browser in GUI mode with a default URL
exec "$BROWSER" \
    --no-sandbox \
    --disable-gpu \
    --remote-debugging-port=9222 \
    --start-maximized \
    --no-first-run \
    --no-default-browser-check \
    --user-data-dir=/tmp/chromium-data \
    "https://www.google.com"
