#!/bin/bash
# Enable logging
exec > /tmp/startup.log 2>&1
set -x

# Find the browser
if command -v ungoogled-chromium &> /dev/null; then
    BROWSER="ungoogled-chromium"
elif command -v chromium &> /dev/null; then
    BROWSER="chromium"
else
    BROWSER=$(find /nix/store -maxdepth 4 -type f -executable -name "chromium" 2>/dev/null | head -n 1)
fi

if [ -z "$BROWSER" ]; then
    echo "Chromium not found"
    exit 1
fi

echo "Launching $BROWSER with extreme performance optimizations..."

# Launch browser with advanced performance and low-latency flags
exec "$BROWSER" \
    --no-sandbox \
    --disable-gpu \
    --start-maximized \
    --no-first-run \
    --no-default-browser-check \
    --user-data-dir=/tmp/chromium-data \
    --disable-dev-shm-usage \
    --js-flags="--max-old-space-size=4096 --expose-gc" \
    --disable-extensions \
    --disable-component-extensions-with-background-pages \
    --disable-background-networking \
    --disable-sync \
    --metrics-recording-only \
    --disable-default-apps \
    --mute-audio \
    --no-service-autorun \
    --disable-software-rasterizer \
    --disable-background-timer-throttling \
    --disable-backgrounding-occluded-windows \
    --disable-breakpad \
    --disable-ipc-flooding-protection \
    --disable-hang-monitor \
    --disable-prompt-on-repost \
    --disable-renderer-backgrounding \
    --force-color-profile=srgb \
    --num-raster-threads=4 \
    --enable-zero-copy \
    "https://www.google.com"
