def wait_for_vnc(port, timeout=30):
    """Wait for VNC, verifying the RFB handshake. Returns the working address."""
    start = time.time()
    while time.time() - start < timeout:
        for host in ["127.0.0.1", "::1"]:
            try:
                af = socket.AF_INET6 if ":" in host else socket.AF_INET
                s = socket.socket(af, socket.SOCK_STREAM)
                s.settimeout(2)
                s.connect((host, port))
                data = s.recv(12)
                s.close()
                if data.startswith(b"RFB"):
                    print(f"VNC confirmed on {host}:{port}")
                    return host
            except OSError:
                pass
        time.sleep(0.5)
    return "::1"

def _force_remove(func, path, exc):
    parent = os.path.dirname(path)
    try:
        os.chmod(parent, 0o755)
    except Exception:
        pass
    try:
        os.chmod(path, 0o755)
    except Exception:
        pass
    func(path)

def setup_novnc_web():
    if os.path.exists(NOVNC_WEB):
        subprocess.run(["chmod", "-R", "u+w", NOVNC_WEB], capture_output=True)
        shutil.rmtree(NOVNC_WEB, onerror=_force_remove)
    shutil.copytree(NOVNC_SRC, NOVNC_WEB)
    os.chmod(NOVNC_WEB, 0o755)
    for root, dirs, files in os.walk(NOVNC_WEB):
        for d in dirs:
            os.chmod(os.path.join(root, d), 0o755)
