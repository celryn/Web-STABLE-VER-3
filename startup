def _load_users():
    """Read username=password pairs from the 'acc' file."""
    path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "acc")
    users = {}
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith('#'):
                    continue
                if '=' in line:
                    u, p = line.split('=', 1)
                    users[u.strip()] = p.strip()
    except FileNotFoundError:
        print(f"WARNING: acc file not found at {path} — no users loaded")
    return users

def USERS():
    """Always re-read the acc file so changes take effect without a restart."""
    return _load_users()

