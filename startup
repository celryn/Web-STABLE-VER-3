#!/bin/bash
# Exit on any error
set -e

# Define profile directory
PROFILE_DIR="$HOME/.config/chromium-profile"

# Remove potential lock files and cleanup before starting
rm -rf "$PROFILE_DIR/SingletonLock" "$PROFILE_DIR/SingletonCookie" "$PROFILE_DIR/SingletonSocket"
rm -rf ~/.config/chromium/SingletonLock ~/.config/google-chrome/SingletonLock

# Check for ungoogled-chromium or chromium
if command -v ungoogled-chromium &> /dev/null; then
    BROWSER="ungoogled-chromium"
elif command -v chromium &> /dev/null; then
    BROWSER="chromium"
else
    # Fallback search in nix store
    BROWSER=$(ls /nix/store/*/bin/chromium 2>/dev/null | head -n 1)
fi

if [ -z "$BROWSER" ]; then
    echo "Error: Chromium/Ungoogled-Chromium not found."
    exit 1
fi

echo "Starting $BROWSER..."

# Launch browser with stability flags
# --dbus-stub: Disables D-Bus connection
# --disable-gpu: prevents GPU-related crashes
# --disable-software-rasterizer: prevents software rendering issues
# --no-sandbox: required for many container environments
# --no-zygote: disables zygote process
# --headless=new: Run in a more stable headless mode that doesn't rely on X11/Bus
# --remote-debugging-address=0.0.0.0: allows external inspection
# --remote-debugging-port=9222
# --disable-features=VizDisplayCompositor: bypasses some display bus requirements
exec "$BROWSER" \
    --no-sandbox \
    --disable-gpu \
    --disable-dev-shm-usage \
    --disable-software-rasterizer \
    --start-maximized \
    --no-first-run \
    --remote-debugging-port=9222 \
    --remote-debugging-address=0.0.0.0 \
    --user-data-dir="$PROFILE_DIR" \
    --no-zygote \
    --dbus-stub \
    --disable-features=VizDisplayCompositor \
    --headless=new
