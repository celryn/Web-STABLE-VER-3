_DEVICES_FILE = os.path.join(os.path.dirname(os.path.abspath(__file__)), "devices.json")
_devices_lock = threading.Lock()

def _load_devices():
    try:
        with open(_DEVICES_FILE) as f:
            return _json.load(f)
    except (FileNotFoundError, ValueError):
        return {}

def _save_devices(data):
    with open(_DEVICES_FILE, 'w') as f:
        _json.dump(data, f, indent=2)

def _record_device(username, fingerprint, label):
    with _devices_lock:
        data = _load_devices()
        if username not in data:
            data[username] = {}
        now = time.strftime('%Y-%m-%d %H:%M UTC', time.gmtime())
        if fingerprint not in data[username]:
            data[username][fingerprint] = {
                'label': label,
                'first_seen': now,
                'last_seen': now,
                'logins': 1,
            }
        else:
            data[username][fingerprint]['last_seen'] = now
            data[username][fingerprint]['logins'] += 1
            if label and label != 'Unknown on Unknown':
                data[username][fingerprint]['label'] = label
        _save_devices(data)

def kill_port_users(port):
    """Kill any process listening on the given port via /proc/net/tcp*."""
    hex_port = format(port, 'X').zfill(4)
    pids_killed = set()
    for proto in ['tcp', 'tcp6']:
        try:
            with open(f'/proc/net/{proto}') as f:
                for line in f.readlines()[1:]:
                    parts = line.split()
                    if len(parts) < 4:
                        continue
                    local = parts[1]
                    local_port = local.split(':')[1]
                    if local_port.upper() == hex_port:
                        inode = parts[9]
                        for pid in os.listdir('/proc'):
                            if not pid.isdigit() or pid in pids_killed:
                                continue
                            try:
                                fd_dir = f'/proc/{pid}/fd'
                                for fd in os.listdir(fd_dir):
                                    link = os.readlink(f'{fd_dir}/{fd}')
                                    if f'socket:[{inode}]' in link:
                                        os.kill(int(pid), 9)
                                        pids_killed.add(pid)
                            except (PermissionError, FileNotFoundError, ProcessLookupError):
                                pass
        except FileNotFoundError:
            pass
    if pids_killed:
        print(f"Killed PIDs using port {port}: {pids_killed}")

