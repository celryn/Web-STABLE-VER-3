def kill_port_users(port):
    """Kill any process listening on the given port via /proc/net/tcp*."""
    hex_port = format(port, 'X').zfill(4)
    pids_killed = set()
    for proto in ['tcp', 'tcp6']:
        try:
            with open(f'/proc/net/{proto}') as f:
                for line in f.readlines()[1:]:
                    parts = line.split()
                    if len(parts) < 4:
                        continue
                    local = parts[1]
                    local_port = local.split(':')[1]
                    if local_port.upper() == hex_port:
                        inode = parts[9]
                        for pid in os.listdir('/proc'):
                            if not pid.isdigit() or pid in pids_killed:
                                continue
                            try:
                                fd_dir = f'/proc/{pid}/fd'
                                for fd in os.listdir(fd_dir):
                                    link = os.readlink(f'{fd_dir}/{fd}')
                                    if f'socket:[{inode}]' in link:
                                        os.kill(int(pid), 9)
                                        pids_killed.add(pid)
                            except (PermissionError, FileNotFoundError, ProcessLookupError):
                                pass
        except FileNotFoundError:
            pass
    if pids_killed:
        print(f"Killed PIDs using port {port}: {pids_killed}")

def kill_old_processes():
    for name in ["x11vnc", "Xvfb", "websockify", "chromium", "ungoogled-chromium"]:
        subprocess.run(["pkill", "-9", "-f", name], capture_output=True)
    time.sleep(1)
    kill_port_users(VNC_PORT)
    kill_port_users(NOVNC_PORT)
    # Second pass to catch any survivors
    for name in ["websockify", "x11vnc"]:
        subprocess.run(["pkill", "-9", "-f", name], capture_output=True)
    time.sleep(1)

def wait_for_vnc(port, timeout=30):
    """Wait for VNC, verifying the RFB handshake. Returns the working address."""
    start = time.time()
    while time.time() - start < timeout:
        for host in ["127.0.0.1", "::1"]:
            try:
                af = socket.AF_INET6 if ":" in host else socket.AF_INET
                s = socket.socket(af, socket.SOCK_STREAM)
                s.settimeout(2)
                s.connect((host, port))
                data = s.recv(12)
                s.close()
                if data.startswith(b"RFB"):
                    print(f"VNC confirmed on {host}:{port}")
                    return host
            except OSError:
                pass
        time.sleep(0.5)
    return "::1"

def _force_remove(func, path, exc):
    parent = os.path.dirname(path)
    try:
        os.chmod(parent, 0o755)
    except Exception:
        pass
    try:
        os.chmod(path, 0o755)
    except Exception:
        pass
    func(path)

