def run_xvfb():
    print("Starting Xvfb...")
    subprocess.run([
        "Xvfb", DISPLAY,
        "-screen", "0", "1280x800x24",
        "-ac"
    ])

def run_browser():
    browser = None
    for cmd in ["ungoogled-chromium", "chromium"]:
        try:
            subprocess.run(["which", cmd], check=True, capture_output=True)
            browser = cmd
            break
        except subprocess.CalledProcessError:
            continue

    if not browser:
        try:
            res = subprocess.run(
                "find /nix/store -maxdepth 4 -type f -executable -name 'chromium' | head -n 1",
                shell=True, capture_output=True, text=True
            )
            browser = res.stdout.strip()
        except Exception:
            pass

    if not browser:
        print("Chromium not found")
        return

    print(f"Launching {browser}...")
    env = os.environ.copy()
    env["DISPLAY"] = DISPLAY

    while True:
        try:
            subprocess.run([
                browser,
                "--no-sandbox",
                "--disable-gpu",
                "--user-data-dir=/tmp/chromium-data",
                "--disable-dev-shm-usage",
                "--no-first-run",
                "--no-default-browser-check",
                "--window-size=1280,800",
                "--start-maximized",
                "--disable-extensions",
                "--disable-background-networking",
                "--disable-sync",
                "--disable-translate",
                "--disable-hang-monitor",
                "--disable-component-update",
                "--disable-default-apps",
                "--disable-client-side-phishing-detection",
                "--disable-features=TranslateUI,Translate",
                "--disable-ipc-flooding-protection",
                "--disable-renderer-backgrounding",
                "--disable-backgrounding-occluded-windows",
                "--metrics-recording-only",
                "--disk-cache-size=104857600",
                "--memory-pressure-off",
                "--max-tiles-for-interest-area=128",
                "https://www.google.com"
            ], env=env)
        except Exception as e:
            print(f"Browser error: {e}")
            time.sleep(2)
        else:
            print("Browser exited, restarting in 2s...")
            time.sleep(2)

def run_x11vnc():
    print("Starting x11vnc...")
    time.sleep(3)
    while True:
        try:
            subprocess.run([
                "x11vnc",
                "-display", DISPLAY,
                "-nopw",
                "-rfbport", str(VNC_PORT),
                "-forever",
                "-shared",
                "-quiet",
                "-noxdamage",
                "-threads",
                "-defer", "5",
                "-wait", "5",
                "-speeds", "modem",
                "-ncache", "10",
                "-ncache_cr",
            ])
        except Exception as e:
            print(f"x11vnc error: {e}")
            time.sleep(2)
        else:
            time.sleep(1)

def run_novnc(vnc_host):
    if ":" in vnc_host:
        target = f"[{vnc_host}]:{VNC_PORT}"
    else:
        target = f"{vnc_host}:{VNC_PORT}"
    print(f"Starting noVNC on :{NOVNC_PORT} -> {target}")
    env = os.environ.copy()
    numpy_path = "/nix/store/12nkx5irbnfdh06frm3sxs7drdw9ah4r-python3.11-numpy-1.26.4/lib/python3.11/site-packages"
    existing = env.get("PYTHONPATH", "")
    env["PYTHONPATH"] = f"{numpy_path}:{existing}" if existing else numpy_path
    while True:
        try:
            subprocess.run([
                "websockify",
                "--web", NOVNC_WEB,
                str(NOVNC_PORT),
                target
            ], env=env)
        except Exception as e:
            print(f"noVNC error: {e}")
        time.sleep(3)

if __name__ == "__main__":
    print("Cleaning up old processes...")
    kill_old_processes()

    os.makedirs("/tmp/chromium-data", exist_ok=True)
    setup_novnc_web()

    threading.Thread(target=run_xvfb, daemon=True).start()
    time.sleep(1)

    threading.Thread(target=run_browser, daemon=True).start()
    threading.Thread(target=run_x11vnc, daemon=True).start()

    print("Waiting for VNC server...")
    vnc_host = wait_for_vnc(VNC_PORT, timeout=30)
    print(f"VNC ready at {vnc_host}:{VNC_PORT}")

    run_novnc(vnc_host)
